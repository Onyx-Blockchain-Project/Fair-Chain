# Vercel Environment Variables
# Copy this to .env and fill in your values

# API Configuration
# Use your Render backend URL after deployment
VITE_API_URL=https://fairchain-backend.onrender.com/api

# Stellar Configuration
VITE_STELLAR_NETWORK=TESTNET
VITE_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs (fill after deploying contracts)
VITE_FACTORY_REGISTRY_CONTRACT_ID=
VITE_AUDITOR_STAKING_CONTRACT_ID=
VITE_AUDIT_REGISTRY_CONTRACT_ID=
VITE_REPUTATION_ORACLE_CONTRACT_ID=
VITE_DISPUTE_RESOLUTION_CONTRACT_ID=
VITE_TRADE_FINANCE_CONTRACT_ID=

# IPFS Configuration
VITE_INFURA_PROJECT_ID=your_infura_project_id
VITE_INFURA_SECRET=your_infura_secret

# Analytics (optional)
VITE_GOOGLE_ANALYTICS_ID=
