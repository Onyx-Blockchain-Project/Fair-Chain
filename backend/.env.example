PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fairchain
DB_USER=fairchain_user
DB_PASSWORD=Onyx99@pgsql

# Stellar
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract IDs (to be filled after deployment)
FACTORY_REGISTRY_CONTRACT_ID=
AUDITOR_STAKING_CONTRACT_ID=
AUDIT_NFT_CONTRACT_ID=
REPUTATION_ORACLE_CONTRACT_ID=
RWA_WRAPPER_CONTRACT_ID=
DISPUTE_RESOLUTION_CONTRACT_ID=

# IPFS Service Configuration
IPFS_SERVICE=mock
# Options: mock, pinata, infura

# For production services:
# PINATA_API_KEY=your_pinata_api_key
# PINATA_SECRET_KEY=your_pinata_secret_key
# INFURA_PROJECT_ID=your_infura_project_id
# INFURA_PROJECT_SECRET=your_infura_secret

# IPFS Gateway
IPFS_GATEWAY=https://ipfs.io/ipfs

# Admin
ADMIN_SECRET_KEY=
